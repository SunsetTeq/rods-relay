APP_NAME=RODS Relay
APP_VERSION=0.1.0
API_PORT=8000

# Public host used by mobile clients and the edge backend.
# For a quick VPS setup without a custom domain, you can often use:
# RELAY_PUBLIC_HOST=<your-server-ip>.sslip.io
RELAY_PUBLIC_SCHEME=https
RELAY_PUBLIC_HOST=relay.example.com

# Public RTMP ingest port exposed for rods-backend.
RELAY_RTMP_PORT=1935

# Public WebRTC media port exposed for SRS. Keep it UDP and open it in firewall.
RELAY_RTC_PORT=8000

# Public IPv4 of the relay server used as WebRTC candidate.
# Use raw IPv4 here, not a hostname.
RELAY_RTC_CANDIDATE=203.0.113.10

# Public paths served via Caddy over HTTPS.
RELAY_DEFAULT_APP=live
RELAY_DEFAULT_STREAM=rods

# Internal service URLs inside Docker network.
SRS_HTTP_API_URL=http://srs:1985
SRS_HTTP_SERVER_URL=http://srs:8080

# Optional upstream rods-backend URL for JSON, screenshot and websocket proxying.
# Example: https://edge-backend.example.com
BACKEND_API_BASE_URL=
BACKEND_REQUEST_TIMEOUT_SECONDS=5.0
